generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PendingCommand {
  id        Int      @id @default(autoincrement())
  command   String
  executed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Order {
  id          String   @id
  status      String   @default("PENDING")
  pixCode     String?
  qrCode      String?
  checkoutUrl String?
  price       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   
}

model VipOrder {
  id                String   @id @default(uuid())
  steamId           String
  status            String   @default("PENDING")
  durationDays      Int      @default(30) 
  vipGroup          String   @default("vip1")
  expiresAt         DateTime
  notifiedAdd       Boolean  @default(false)
  notifiedDel       Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([steamId])
}

model Session {
  sid    String   @id @db.VarChar
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session") 
}

model PlayerWeaponSkin {
  id              String   @id @default(uuid())
  steamId         String   
  weaponName      String   

  // propriedades de arma 
  paintKit        Int      @default(0)   // skin id 
  wearFloat       Float    @default(0.0) // desgaste
  statTrak        Boolean  @default(false)
  statTrakCount   Int      @default(0)
  nameTag         String   @default("")
  seed            Int      @default(-1)  // Pattern
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([steamId])
  @@unique([steamId, weaponName]) 
}

model PlayerGlove {
  steamId   String   @id
  
  tGroup    Int      @default(0)
  tGlove    Int      @default(0)
  tFloat    Float    @default(0.0)
  
  ctGroup   Int      @default(0)
  ctGlove   Int      @default(0)
  ctFloat   Float    @default(0.0)
  updatedAt DateTime @updatedAt
}


model PlayerStats {
  steamId           String   @id 
  zombieDamage      Int      @default(0)
  bossDamage        Int      @default(0)
  playtimeMinutes   Int      @default(0)
  zombieTankDamage  Int      @default(0)
  humansInfected    Int      @default(0)
  roundsSurvived    Int      @default(0)
  updatedAt         DateTime @updatedAt
}


model Quest {
  id              Int      @id @default(autoincrement())
  title           String  
  description     String   
  type            String   // 'ZOMBIE_DAMAGE', 'BOSS_DAMAGE', 'PLAYTIME'
  targetValue     Int     
  eventName       String? 
  useridField     String? 
  conditions      Json?
  rewardCredits   Int      @default(0) 
  rewardItem      String?  // nome interno do Player Model (ex: "sephiroth_model")
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  
  playerQuests    PlayerQuest[]
}

model ServerAdmin {
  steamId   String   @id
  name      String?  
  addedAt   DateTime @default(now())
}

model PlayerQuest {
  id              Int      @id @default(autoincrement())
  steamId         String
  questId         Int
  progress        Int      @default(0)
  status          String   @default("IN_PROGRESS") // 'IN_PROGRESS', 'COMPLETED', 'CLAIMED', 'PENDING_DELIVERY'
  updatedAt       DateTime @updatedAt

  quest           Quest    @relation(fields: [questId], references: [id])
  
  @@unique([steamId, questId])
}

model QuestTemplate {
  id              String   @id @default(uuid())
  tier            String   // Pode ser 'DAILY', 'WEEKLY' ou 'MONTHLY'
  type            String   // 'ZOMBIE_DAMAGE', 'BOSS_DAMAGE', 'PLAYTIME'
  eventName       String?   // Ex: 'player_hurt'
  useridField     String?
  titles          Json     
  descriptions    Json     

  // A inteligência do balanceamento:
  minTarget       Int      // Meta mínima (Ex: 10000 de dano)
  maxTarget       Int      // Meta máxima (Ex: 50000 de dano)
  minReward       Int      // Recompensa mínima
  maxReward       Int      // Recompensa máxima

  // Condições nativas que o template sempre deve injetar (Ex: ser CT, atirar em TR)
  baseConditions  Json?    

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}